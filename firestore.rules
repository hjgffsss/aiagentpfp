rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // "applications" — submissions are created via the server-side API
    // route (app/api/applications/route.ts) using the Admin SDK, which
    // bypasses these rules. Direct client reads/writes are blocked so
    // applicants can never read each other's data or tamper with status.
    match /applications/{appId} {
      allow read: if false;
      allow write: if false;
    }

    // "whitelist" — eligibility records. Read-only lookups happen through
    // the server-side eligibility API, not directly from the browser.
    match /whitelist/{entryId} {
      allow read: if false;
      allow write: if false;
    }

    // "leaderboard" — real agent points, keyed by wallet address. Reads
    // and writes both go through server-side API routes
    // (app/api/leaderboard/route.ts, app/api/applications/route.ts) using
    // the Admin SDK. Blocked here so a client can never inflate their own
    // points or read another wallet's raw document directly.
    match /leaderboard/{walletId} {
      allow read: if false;
      allow write: if false;
    }

    // "admins" — admin identities, managed manually or via a trusted
    // backend script. Never exposed to clients.
    match /admins/{adminId} {
      allow read, write: if false;
    }

    // "roles" — role assignment metadata, server-managed only.
    match /roles/{roleId} {
      allow read, write: if false;
    }

    // "settings" — project-wide config (mint date, supply, etc.) that the
    // public site may read, but never write.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny for anything not explicitly listed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
