# ---------------------------------------------------------------------------
# Crypto Agent — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or real secrets to git.
# ---------------------------------------------------------------------------

# WalletConnect / Web3Modal Project ID — REQUIRED for wallet connect to work
# (both the navbar button and the whitelist bot). This is a PUBLIC
# identifier, not a secret — safe to expose in client code.
# Get a free one at https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Firebase (client SDK) — from Firebase Console > Project Settings > General
# Currently unused by default (this build's API routes use the Admin SDK
# below), but kept here in case you add client-side Firestore reads later
# — those would need their own security rules.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side only) — REQUIRED for the app to persist
# whitelist applications, the real points leaderboard, and eligibility
# lookups in Firestore. Without this, those features show an honest
# "not connected" state rather than fake/demo data.
# Generate from Firebase Console > Project Settings > Service Accounts >
# Generate New Private Key. Paste the JSON file's matching fields below.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Admin dashboard login (simple credential gate — see lib/admin-session.ts)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Used to sign admin session cookies. Use a long, random string.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=
